# ============================================================================
#  Environment template — SAFE to commit (contains no real values).
#
#  Do NOT edit this file with your keys. Run `npm run setup` instead; it copies
#  this to `.env` (which is git-ignored) and prompts for secrets without echoing
#  them to your terminal.
#
#  ⚠  NEVER paste your real .env, API key, or this file (once filled in) into a
#     GitHub issue, screenshot, chat, or pull request. To share diagnostics,
#     run `npm run doctor` — its output is redacted and safe to share.
# ============================================================================

# --- Steam ---
# Key:  https://steamcommunity.com/dev/apikey   (domain "localhost" is fine)
# ID:   17-digit SteamID64 from https://steamid.io  (profile must be Public)
STEAM_API_KEY=
STEAM_ID=

# --- GOG (optional) — your GOG library alongside Steam ---
# GOG has no developer API key. Run `npm run gog-login` once: it walks you
# through a browser login and writes the long-lived refresh token below for you.
# Don't fill this in by hand.
GOG_REFRESH_TOKEN=

# --- IGDB (optional) — accurate per-game time-to-beat for backlog hours ---
# Register a free app at https://dev.twitch.tv/console/apps (OAuth redirect:
# http://localhost). Copy the Client ID and generate a Client Secret.
IGDB_CLIENT_ID=
IGDB_CLIENT_SECRET=

# Backend API port the Vite dev server proxies /api/* to (see vite.config.ts).
# Kept separate from the web PORT so the two servers never collide.
API_PORT=8787
