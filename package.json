{
  "name": "trovekeeper",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "setup": "node scripts/setup.mjs",
    "doctor": "node scripts/doctor.mjs",
    "whoami": "node scripts/whoami.mjs",
    "gog-login": "node scripts/gog-login.mjs",
    "epic-login": "node scripts/epic-login.mjs",
    "psn-login": "node scripts/psn-login.mjs",
    "dev": "concurrently -k -n web,api -c cyan,green \"vite\" \"npm run server\"",
    "web": "vite",
    "server": "tsx watch server/index.ts",
    "typecheck": "tsc -b && tsc -p tsconfig.server.json",
    "build": "tsc -b && tsc -p tsconfig.server.json && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
